{
  "_comment": "Add this block to the 'agents' section of your openclaw.json config.",
  "_comment2": "Replace all YOUR_* placeholders before applying.",
  "_comment3": "After editing openclaw.json, restart the gateway: docker compose restart openclaw-gateway",

  "YOUR_AGENT_ID": {
    "workspace": "/home/YOUR_SYSTEM_USER/openclaw-workspace/YOUR_AGENT_ID",
    "sandbox": {
      "image": "openclaw-sandbox:latest",
      "env": {
        "AGENT_ID": "YOUR_AGENT_ID",
        "HOME": "/tmp"
      },
      "volumes": {
        "/home/YOUR_SYSTEM_USER/code/spark-ai-agents/shared": "/shared",
        "/usr/local/bin/gmail-agent": "/scripts:ro",
        "/home/YOUR_SYSTEM_USER/.local/share/gsuite-mcp": "/tmp/.local/share/gsuite-mcp:rw",
        "/home/YOUR_SYSTEM_USER/.config/gsuite-mcp": "/tmp/.config/gsuite-mcp:ro"
      }
    },
    "slack_channels": [
      "YOUR_SLACK_CHANNEL_ID"
    ],
    "slack_allowlist": [
      "YOUR_SLACK_USER_ID"
    ]
  }
}
